# Copy to .env.local and fill in real values. .env.local is gitignored.
#
# On Vercel: set the same vars in Project Settings → Environment Variables,
# scoped to Production + Preview + Development (uncheck Development to avoid
# accidentally pushing prod secrets to local dev).

# --- Anthropic ---
# Sonnet 4.6 (generator) and Haiku 4.5 (classifier) via direct SDK.
# Get from: console.anthropic.com → Settings → API Keys → Create Key
ANTHROPIC_API_KEY=

# --- Supabase ---
# Project URL, e.g. https://xxxx.supabase.co
# Get from: supabase.com/dashboard → Project → Settings → Data API → Project URL
NEXT_PUBLIC_SUPABASE_URL=
# Anon (publishable) key — safe in the browser, RLS enforced.
# Get from: same page → "anon" public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key — server only. Never expose to the browser.
# Get from: same page → "service_role" key (click "Reveal")
SUPABASE_SERVICE_ROLE_KEY=

# --- App ---
# (No NEXT_PUBLIC_APP_URL needed. The login page builds the auth callback URL
# from window.location.origin, which is correct in both dev and prod. The
# production origin must be whitelisted in Supabase → Authentication →
# URL Configuration → Redirect URLs.)

# --- DatoCMS (optional — data entry sync) ---
# If absent, the confirm endpoint skips DatoCMS and returns skipped: true.
# Get from: datocms.com → your site → Settings → API tokens → Create "Full-access" token
DATOCMS_API_TOKEN=
# The model ID for the event item type in your DatoCMS site (e.g. "12345")
# Get from: datocms.com → your site → Settings → Models → your event model → ID shown in URL
DATOCMS_EVENT_MODEL_ID=
