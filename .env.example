# Copy to .env.local and fill in real values. .env.local is gitignored.
#
# On Vercel: set the same vars in Project Settings → Environment Variables,
# scoped to Production + Preview + Development (uncheck Development to avoid
# accidentally pushing prod secrets to local dev).

# --- Anthropic ---
# Sonnet 4.6 (generator) and Haiku 4.5 (classifier) via direct SDK.
# Get from: console.anthropic.com → Settings → API Keys → Create Key
ANTHROPIC_API_KEY=

# --- Supabase ---
# Project URL, e.g. https://xxxx.supabase.co
# Get from: supabase.com/dashboard → Project → Settings → Data API → Project URL
NEXT_PUBLIC_SUPABASE_URL=
# Anon (publishable) key — safe in the browser, RLS enforced.
# Get from: same page → "anon" public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key — server only. Never expose to the browser.
# Get from: same page → "service_role" key (click "Reveal")
SUPABASE_SERVICE_ROLE_KEY=

# --- App ---
# (No NEXT_PUBLIC_APP_URL needed. The login page builds the auth callback URL
# from window.location.origin, which is correct in both dev and prod. The
# production origin must be whitelisted in Supabase → Authentication →
# URL Configuration → Redirect URLs.)

# Base URL for dashboard links in notifications. Set to your deployment URL.
NEXT_PUBLIC_SITE_URL=https://tazkar.co

# --- DatoCMS (optional — data entry sync) ---
# If absent, the confirm endpoint skips DatoCMS and returns skipped: true.
# Get from: datocms.com → your site → Settings → API tokens → Create "Full-access" token
DATOCMS_API_TOKEN=
# The model ID for the event item type in your DatoCMS site (e.g. "12345")
# Get from: datocms.com → your site → Settings → Models → your event model → ID shown in URL
DATOCMS_EVENT_MODEL_ID=

# --- WhatsApp change management (v1.6) ---
# Set to "meta" or "360dialog" to select the adapter.
WHATSAPP_PROVIDER=
# Meta Cloud API — get from Meta for Developers → your app → WhatsApp → Configuration
META_APP_SECRET=
META_PERMANENT_TOKEN=
META_PHONE_NUMBER_ID=
# Verify token — any random string you configure in the Meta webhook settings
META_WEBHOOK_VERIFY_TOKEN=
# 360dialog — get from 360dialog Hub → your WABA → API keys
DIALOG360_API_KEY=
DIALOG360_WABA_ID=
# Cron secret — Vercel passes this as "Authorization: Bearer <secret>" to cron routes
# Generate a random string: openssl rand -base64 32
CRON_SECRET=

# --- Email (weekly digest cron) ---
# Set ONE of these to enable email sending. If both are absent, emails are logged to console only (dev mode).
# Resend (preferred): resend.com → API Keys → Create key. Verify noreply@tazkar.co as your domain first.
RESEND_API_KEY=
# SendGrid (alternative): sendgrid.com → Settings → API Keys → Create key (Mail Send permission).
SENDGRID_API_KEY=

# --- Payment webhooks (recovery attribution) ---
# Signed PSP webhooks confirm recovered payments at /api/webhooks/payments/[provider].
# Single-tenant for the pilot (one secret per provider; per-operator secrets deferred).
# Checkout.com: Dashboard → Webhooks → signature key (verifies the cko-signature header).
CHECKOUT_WEBHOOK_SECRET=
# Tap Payments: Dashboard → Webhooks → secret (verifies the hashstring header).
TAP_WEBHOOK_SECRET=
